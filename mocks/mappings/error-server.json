{
    "priority":  1,
    "request":  {
                    "method":  "ANY",
                    "urlPattern":  "/api/v1/.*",
                    "headers":  {
                                    "x-fault":  {
                                                    "equalTo":  "500"
                                                }
                                }
                },
    "response":  {
                     "status":  500,
                     "bodyFileName":  "error-server-body.json",
                     "headers":  {
                                     "Content-Type":  "application/json"
                                 }
                 }
}
